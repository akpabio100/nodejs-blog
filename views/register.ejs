<div class="page-container">
  <h3>Register</h3>

  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>

  <form action="/register" method="POST">

    <label for="username"><b>Username</b></label>
    <input id="username" type="text" placeholder="Enter Username" name="username" autocomplete="username" required>

    <label for="email"><b>Email</b></label>
    <input id="email" type="email" placeholder="Enter Email" name="email" autocomplete="email">

    <label for="phone"><b>Phone</b></label>
    <input id="phone" type="tel" placeholder="Enter Phone" name="phone">

    <label for="address"><b>Address</b></label>
    <input id="address" type="text" placeholder="Enter Address" name="address">

  <% /* country dropdown with searchable datalist */ %>
  <%- include('partials/countryselect') %>

  <label for="password"><b>Password</b></label>
  <div class="input-wrapper">
    <input id="password" type="password" placeholder="Enter Password" name="password" autocomplete="new-password" required>
    <button type="button" class="toggle-password" aria-label="Show password">&#128065;</button>
  </div>
  <small>Password must be at least 8 characters and include uppercase, lowercase, number and symbol</small>

  <label for="confirm"><b>Confirm Password</b></label>
  <div class="input-wrapper">
    <input id="confirm" type="password" placeholder="Re-enter Password" name="confirm" autocomplete="new-password" required>
    <button type="button" class="toggle-password" aria-label="Show password">&#128065;</button>
  </div>
    <label>
      <input type="checkbox" name="terms" required> I agree to the <a href="/terms">Terms & Conditions</a>
    </label>

    <input type="submit" value="Register" class="btn">

    <p>Already have an account? <a href="/login">Login here</a></p>
  </form>
</div>
