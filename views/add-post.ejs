<section class="page">
  <div class="page-container">
    <h2>Add New Post</h2>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/post/add" method="POST" class="form-post">
      <label for="title">Title</label>
      <input type="text" name="title" id="title" placeholder="Enter post title" required>

      <label for="body">Comment</label>
      <textarea name="body" id="body" rows="10" placeholder="Write your comment here..." required></textarea>

      <button type="submit" class="btn">Publish</button>
    </form>
  </div>
</section>
